rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Reservations: anyone can create or look up their own booking
    match /reservationList/{reservationId} {
      allow create: if request.resource.data.keys().hasAll([
                        'email', 'lastName', 'status', 'type',
                        'totalAmount', 'roomSelections', 'customerInfo'
                      ])
                      && request.resource.data.status == 'Upcoming'
                      && request.resource.data.type == 'Stay'
                      && request.resource.data.totalAmount is number
                      && request.resource.data.totalAmount >= 0;

      allow read: if true;

      allow update: if request.resource.data.keys().hasAll(['status', 'lastUpdateTime'])
                      && request.resource.data.status in ['Upcoming', 'Canceled'];

      // Pet registration sub-collection
      match /petRegistration/{petId} {
        allow read, create: if true;
      }
    }

    // Event / wedding inquiries: write-only from the client
    match /eventsRequestList/{docId} {
      allow create: if request.resource.data.keys().hasAll(['type', 'email'])
                      && request.resource.data.type == 'Event/Meeting Inquiry';
      allow read: if false;
    }

    match /weddingRequestList/{docId} {
      allow create: if request.resource.data.keys().hasAll(['type', 'email'])
                      && request.resource.data.type == 'Wedding Inquiry';
      allow read: if false;
    }

    // Customer service & subscriptions: write-only from the client
    match /customerServiceRequest/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email']);
      allow read: if false;
    }

    match /subscriptionList/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email']);
      allow read: if false;
    }

    // New newsletter subscriptions (deduplicated by email query)
    match /newsletters/{docId} {
      allow create: if request.resource.data.keys().hasAll(['email', 'subscribedAt'])
                      && request.resource.data.email is string
                      && request.resource.data.email.size() > 0;
      allow read: if true;  // needed for duplicate-email query
    }

    // Contact enquiries (with booking number)
    match /contacts/{docId} {
      allow create: if request.resource.data.keys().hasAll(['refId', 'email', 'bookingNumber', 'createdAt'])
                      && request.resource.data.email is string
                      && request.resource.data.bookingNumber is string
                      && request.resource.data.bookingNumber.size() > 0;
      allow read: if false;
    }

    // Wedding requests (new collection with generated orderId)
    match /wedding_requests/{docId} {
      allow create: if request.resource.data.keys().hasAll(['orderId', 'email', 'firstName', 'lastName', 'createdAt'])
                      && request.resource.data.email is string;
      allow read: if false;
    }
  }
}
